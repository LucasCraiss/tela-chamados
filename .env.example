# --- Proxy do Vite (dev): obrigatório para lista em Tickets.vue e POST do formulário sem CORS ---
OCTADESK_API_HOST=seu-subdominio.api002.octadesk.services
OCTADESK_API_TOKEN=sua-chave-aqui
# ou: OCTADESK_X_API_KEY=...
OCTADESK_AGENT_EMAIL=agente@empresa.com.br

# --- Cliente (Tickets.vue + build): expostos no bundle; use com cuidado em produção ---
VITE_OCTADESK_API_HOST=seu-subdominio.api002.octadesk.services
VITE_OCTADESK_X_API_KEY=sua-chave-aqui
# alternativa ao X_API_KEY:
# VITE_OCTADESK_API_TOKEN=sua-chave-aqui
VITE_OCTADESK_AGENT_EMAIL=agente@empresa.com.br

